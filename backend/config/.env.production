## Environment ##
NODE_ENV=production


## Server ##
PORT=8081
HOST=localhost


## Setup jet-logger ##
JET_LOGGER_MODE=file
JET_LOGGER_FILEPATH=jet-logger.log
JET_LOGGER_TIMESTAMP=true
JET_LOGGER_FORMAT=line

## Database ##
DATABASE_URL="postgresql://admin:admin123@localhost:5432/kvy_db?schema=public"

## Other ##
VERIFICATION_MIN_DELAY_MS=1
VERIFICATION_MAX_DELAY_MS=6
VERIFICATION_OUTCOMES=APPROVED,REJECTED,INCONCLUSIVE